# Per firmare la release: copia questo file in "keystore.properties" e compila i campi.
# NON includere keystore.properties o il file .jks in repository pubblici.
#
# Genera prima il keystore (una volta sola, conservalo per sempre):
#   keytool -genkeypair -v -keystore gruzzolo-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias gruzzolo
#
storeFile=/percorso/assoluto/gruzzolo-release.jks
storePassword=LA_TUA_PASSWORD
keyAlias=gruzzolo
keyPassword=LA_TUA_PASSWORD
